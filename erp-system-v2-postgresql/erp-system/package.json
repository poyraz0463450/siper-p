{
  "name": "erp-savunma-sanayi",
  "version": "2.0.0",
  "description": "Savunma Sanayi ERP - Silah Fabrikası Üretim Yönetim Sistemi",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "nodemon server/index.js",
    "client": "cd client && npm start",
    "build": "cd client && npm run build",
    "install-all": "npm install && cd client && npm install",
    "db:migrate": "npx knex migrate:latest",
    "db:migrate:rollback": "npx knex migrate:rollback",
    "db:migrate:status": "npx knex migrate:status",
    "db:seed": "npx knex seed:run",
    "db:reset": "npx knex migrate:rollback --all && npx knex migrate:latest && npx knex seed:run",
    "db:make:migration": "npx knex migrate:make",
    "db:make:seed": "npx knex seed:make"
  },
  "keywords": ["erp", "savunma", "silah", "üretim", "stok", "kalite"],
  "author": "Silah Tasarım Mühendisliği",
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "express": "^4.18.2",
    "knex": "^3.1.0",
    "pg": "^8.13.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "multer": "^1.4.5-lts.1",
    "helmet": "^7.1.0",
    "compression": "^1.7.4",
    "express-rate-limit": "^7.1.5",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
