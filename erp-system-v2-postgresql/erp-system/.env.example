# ═══════════════════════════════════════════════════
# SAVUNMA SANAYİ ERP - Ortam Değişkenleri
# ═══════════════════════════════════════════════════

# Sunucu
PORT=5000
NODE_ENV=development

# PostgreSQL Veritabanı
DB_HOST=localhost
DB_PORT=5432
DB_NAME=erp_savunma
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL=false

# Üretim ortamı için (Heroku, Railway vb.)
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# JWT Güvenlik
JWT_SECRET=DEGISTIR-guclu-bir-anahtar-kullanin-32-karakter-minimum
JWT_EXPIRES_IN=24h

# Dosya Yükleme
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads
